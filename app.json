{
  "expo": {
    "name": "Pop the Hood",
    "slug": "garage-assistant",
    "version": "2.0.0",
    "scheme": "popthehood",
    "orientation": "portrait",
    "newArchEnabled": true,
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTablet": true,
      "bundleIdentifier": "com.popthehood.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDisplayName": "Pop the Hood"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "com.popthehood.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-dev-client",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to add vehicle images."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "The app accesses your camera to scan barcodes and take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0066cc"
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "organization": "apex-optimal",
          "project": "pop-the-hood"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0a24e4bd-4199-4cd2-b77b-5f6694503d9d"
      }
    },
    "owner": "lgassen231",
    "privacyUrl": "https://apexoptimal.dev/popthehood/privacy"
  }
}
