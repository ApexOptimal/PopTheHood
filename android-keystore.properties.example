# Copy this file to android/app/keystore.properties and fill in your values.
# Do not commit keystore.properties or your .keystore file.
# You also need android/app/popthehood.keystore (create via Android Studio:
# Build → Generate Signed Bundle/APK → Create new).

storePassword=your_keystore_password
keyPassword=your_key_password
keyAlias=popthehood
