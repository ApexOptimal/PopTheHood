<?xml version="1.0" encoding="utf-8"?>
<!-- Garage Status – Medium widget. Place at android/app/src/main/res/layout/widget_garage_status.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_garage_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2E2E2E"
    android:orientation="horizontal"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_garage_s1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oil Change"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_garage_s1_mi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1,200 mi left"
            android:textColor="#0066CC"
            android:textSize="12sp" />

        <LinearLayout
            android:id="@+id/widget_garage_row2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/widget_garage_s2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tire Rotation"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/widget_garage_s2_mi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3,200 mi left"
                android:textColor="#0066CC"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_garage_odo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_garage_odo_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="~45,200"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/widget_garage_odo_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Est. odometer"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
