<?xml version="1.0" encoding="utf-8"?>
<!-- Quick Look – Small widget. Place at android/app/src/main/res/layout/widget_quick_look.xml -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_quick_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2E2E2E"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_quick_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Oil Change"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_quick_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Vehicle"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_quick_miles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="1,200 mi left"
            android:textColor="#0066CC"
            android:textSize="12sp" />

        <ProgressBar
            android:id="@+id/widget_quick_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="6dp"
            android:max="5000"
            android:progress="1200"
            android:progressDrawable="@drawable/widget_progress"
            android:progressTint="#0066CC" />
    </LinearLayout>
</FrameLayout>
